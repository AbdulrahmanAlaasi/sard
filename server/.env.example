# Scrivano 2.0 backend configuration — copy to .env and fill in.
# With everything left empty the server runs on SQLite with mock embeddings:
# fine for development, never for production.

# Supabase or local Postgres (pgvector required for ANN search).
# Omit entirely to fall back to sqlite:///db.sqlite3.
DATABASE_URL=

# Supabase project (auth JWT verification + private storage).
SUPABASE_URL=
SUPABASE_JWT_SECRET=
# Server-side only — never expose to a browser.
SUPABASE_SERVICE_KEY=

DJANGO_SECRET_KEY=
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Embeddings provider registry: ollama | mock ("mock" is deterministic,
# clearly labeled in stored records, and never presented as real).
EMBEDDINGS_PROVIDER=mock
EMBEDDINGS_URL=http://localhost:11434
EMBEDDINGS_MODEL=nomic-embed-text

# Document storage backend: local | supabase
DOCUMENT_STORAGE=local
